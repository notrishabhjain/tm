{
  "name": "taskmind",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage-check": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":70,\"functions\":70,\"branches\":60}}'",
    "build:android:debug": "eas build --platform android --profile development --local",
    "build:android:release": "eas build --platform android --profile production --local",
    "prebuild": "expo prebuild --platform android --clean",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed-db.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.76.9",
    "expo": "52.0.46",
    "expo-router": "4.0.20",
    "expo-dev-client": "4.0.29",
    "expo-build-properties": "0.13.2",
    "expo-font": "13.0.4",
    "expo-splash-screen": "0.29.21",
    "expo-status-bar": "2.0.1",
    "expo-sqlite": "15.2.14",
    "drizzle-orm": "0.36.4",
    "react-native-mmkv": "3.2.0",
    "@notifee/react-native": "9.1.7",
    "expo-background-fetch": "12.0.1",
    "expo-task-manager": "12.0.5",
    "react-native-reanimated": "3.16.7",
    "react-native-gesture-handler": "2.21.2",
    "@shopify/flash-list": "1.7.3",
    "@gorhom/bottom-sheet": "5.1.3",
    "react-native-svg": "15.8.0",
    "lucide-react-native": "0.468.0",
    "expo-haptics": "14.0.1",
    "expo-image": "2.0.7",
    "react-hook-form": "7.54.2",
    "zustand": "5.0.3",
    "@tanstack/react-query": "5.62.16",
    "react-native-device-info": "11.1.0",
    "expo-calendar": "13.0.5",
    "expo-file-system": "18.0.12",
    "expo-sharing": "12.0.1",
    "i18next": "23.16.8",
    "react-i18next": "15.1.3",
    "expo-linking": "7.0.5",
    "expo-constants": "17.0.8",
    "@react-native-async-storage/async-storage": "2.1.0"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/react": "18.3.18",
    "@types/react-native": "0.73.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.3",
    "eslint-plugin-react-native": "4.1.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "prettier": "3.4.2",
    "jest": "29.7.0",
    "jest-expo": "52.0.6",
    "@testing-library/react-native": "12.9.0",
    "@testing-library/jest-native": "5.4.3",
    "babel-plugin-transform-inline-environment-variables": "0.4.4",
    "tsx": "4.19.2",
    "drizzle-kit": "0.28.1",
    "@babel/core": "7.25.9",
    "babel-preset-expo": "12.0.9"
  },
  "workspaces": [
    "modules/*"
  ],
  "overrides": {
    "ajv-keywords": {
      "ajv": "8.20.0"
    }
  }
}
