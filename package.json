{
  "name": "taskmind",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "test:coverage-check": "jest --coverage --forceExit --coverageThreshold='{\"global\":{\"lines\":50,\"functions\":50,\"branches\":40}}'",
    "prebuild": "expo prebuild --platform android --clean",
    "build:android:debug": "eas build --platform android --profile development --local",
    "build:android:release": "eas build --platform android --profile production --local",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed-db.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "5.1.4",
    "@notifee/react-native": "9.1.8",
    "@shopify/flash-list": "1.7.3",
    "@tanstack/react-query": "5.75.2",
    "ajv": "^8.20.0",
    "drizzle-orm": "0.40.1",
    "expo": "53.0.9",
    "expo-background-fetch": "13.1.5",
    "expo-build-properties": "0.13.2",
    "expo-calendar": "14.1.3",
    "expo-dev-client": "5.0.12",
    "expo-file-system": "18.1.10",
    "expo-font": "13.3.1",
    "expo-haptics": "14.1.4",
    "expo-image": "2.3.0",
    "expo-router": "4.0.17",
    "expo-sharing": "13.1.5",
    "expo-splash-screen": "0.29.22",
    "expo-sqlite": "15.1.4",
    "expo-status-bar": "2.2.3",
    "i18next": "24.2.3",
    "lucide-react-native": "0.475.0",
    "react": "19.0.0",
    "react-hook-form": "7.56.3",
    "react-i18next": "15.5.1",
    "react-native": "0.79.3",
    "react-native-device-info": "14.0.4",
    "react-native-gesture-handler": "2.24.0",
    "react-native-mmkv": "3.2.0",
    "react-native-reanimated": "3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "4.10.0",
    "react-native-svg": "15.11.2",
    "zustand": "5.0.4"
  },
  "devDependencies": {
    "@babel/core": "7.27.1",
    "@testing-library/jest-native": "5.4.3",
    "@testing-library/react-native": "12.9.0",
    "@types/react": "19.0.0",
    "@typescript-eslint/eslint-plugin": "8.32.1",
    "@typescript-eslint/parser": "8.32.1",
    "babel-plugin-transform-inline-environment-variables": "0.4.4",
    "drizzle-kit": "0.30.4",
    "eslint": "9.26.0",
    "eslint-plugin-react-native": "4.1.0",
    "jest": "29.7.0",
    "jest-expo": "53.0.5",
    "prettier": "3.5.3",
    "tsx": "4.19.3",
    "typescript": "5.8.3"
  }
}
