<?xml version="1.0" encoding="utf-8"?>
<!-- Long-press app icon shortcuts. "Voice task" jumps straight to the create
     screen with the keyboard open — tap the dictation mic (e.g. Wispr Flow)
     and speak; the extraction pipeline derives priority/due date on save. -->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
  <shortcut
      android:shortcutId="voice_task"
      android:enabled="true"
      android:icon="@mipmap/ic_launcher"
      android:shortcutShortLabel="@string/shortcut_voice_task_short"
      android:shortcutLongLabel="@string/shortcut_voice_task_long">
    <intent
        android:action="android.intent.action.VIEW"
        android:targetPackage="com.taskmind.app"
        android:targetClass="com.taskmind.app.MainActivity">
      <extra
          android:name="taskmind_nav_route"
          android:value="/task/create" />
    </intent>
  </shortcut>
</shortcuts>
